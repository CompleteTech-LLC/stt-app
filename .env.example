# Server-only OpenAI API key. Do not expose this value to browser code.
OPENAI_API_KEY=

# Optional model overrides. Defaults are chosen for speed/cost and low-latency live STT.
OPENAI_FILE_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_HIGH_ACCURACY_FILE_STT_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_STT_MODEL=gpt-realtime-whisper

# Optional operational tuning.
MAX_UPLOAD_BYTES=26214400
REQUEST_TIMEOUT_MS=120000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
LOG_TRANSCRIPTS=false
